#: data/moe.ekusu.sprogskole.gschema.xml:11
msgid "Id of the currently connected school"
msgstr "Id for den aktuelt forbundne skole"

#: data/moe.ekusu.sprogskole.gschema.xml:15
msgid "Username of the saved account (secret lives in the keyring)"
msgstr "Brugernavn for den gemte konto (hemmeligheden ligger i nøgleringen)"

#: data/moe.ekusu.sprogskole.gschema.xml:19
msgid "Id of the login method used for the saved account"
msgstr "Id for loginmetoden brugt til den gemte konto"

#: data/moe.ekusu.sprogskole.gschema.xml:23
msgid "Display name of a hand-entered (Custom) school"
msgstr "Visningsnavn for en manuelt indtastet (tilpasset) skole"

#: data/moe.ekusu.sprogskole.gschema.xml:27
msgid "Base URL of a hand-entered (Custom) school"
msgstr "Basis-URL for en manuelt indtastet (tilpasset) skole"

#: data/moe.ekusu.sprogskole.gschema.xml:31
msgid "Provider family of a hand-entered (Custom) school"
msgstr "Udbyderfamilie for en manuelt indtastet (tilpasset) skole"

#: data/moe.ekusu.sprogskole.gschema.xml:35
msgid "Forced UI language"
msgstr "Tvunget grænsefladesprog"

#: data/moe.ekusu.sprogskole.gschema.xml:36
msgid ""
"Language code (e.g. 'da') forcing the app's interface language regardless of "
"the system locale, via the LANGUAGE env var. '' follows the system. Applied "
"at startup (see Localization.apply); a change takes full effect on restart."
msgstr ""
"Sprogkode (f.eks. 'da'), der tvinger appens grænsefladesprog uanset "
"systemets locale via miljøvariablen LANGUAGE. '' følger systemet. Anvendes "
"ved opstart (se Localization.apply); en ændring træder fuldt i kraft efter "
"genstart."

#: data/moe.ekusu.sprogskole.gschema.xml:41
msgid "Preferred color scheme"
msgstr "Foretrukket farveskema"

#: data/moe.ekusu.sprogskole.gschema.xml:42
msgid "0 = follow system, 1 = light, 2 = dark. Applied via AdwStyleManager."
msgstr "0 = følg systemet, 1 = lys, 2 = mørk. Anvendes via AdwStyleManager."

#: data/moe.ekusu.sprogskole.gschema.xml:47
msgid "Preferred accent color"
msgstr "Foretrukket accentfarve"

#: data/moe.ekusu.sprogskole.gschema.xml:48
msgid ""
"0 = follow system; 1–9 = AdwAccentColor (blue, teal, green, yellow, orange, "
"red, pink, purple, slate). Overridden via a CSS provider since "
"AdwStyleManager's accent is read-only."
msgstr ""
"0 = følg systemet; 1–9 = AdwAccentColor (blå, blågrøn, grøn, gul, orange, "
"rød, lyserød, lilla, skifer). Tilsidesættes via en CSS-udbyder, da "
"AdwStyleManagers accent er skrivebeskyttet."

#: data/moe.ekusu.sprogskole.gschema.xml:53
msgid "Day the calendar week starts on"
msgstr "Dagen kalenderugen starter på"

#: data/moe.ekusu.sprogskole.gschema.xml:54
msgid "0 = use the school's default; 1–7 = ISO weekday (1 Monday … 7 Sunday)."
msgstr "0 = brug skolens standard; 1–7 = ISO-ugedag (1 mandag … 7 søndag)."

#: data/moe.ekusu.sprogskole.gschema.xml:58
msgid "Keep running in the background to refresh cached data"
msgstr "Bliv ved med at køre i baggrunden for at opdatere data i cachen"

#: data/moe.ekusu.sprogskole.gschema.xml:59
msgid ""
"On desktop, closing the window hides the app instead of quitting it, and the "
"cache is refreshed periodically (see sync-interval-minutes) so everything "
"keeps working offline. Quit still exits for real."
msgstr ""
"På skrivebordet skjules programmet, når vinduet lukkes, i stedet for at "
"afslutte, og cachen opdateres jævnligt (se sync-interval-minutes), så alt "
"fortsat virker offline. Afslut lukker stadig helt."

#: data/moe.ekusu.sprogskole.gschema.xml:64
msgid "Minutes between background cache refreshes"
msgstr "Minutter mellem opdateringer af cachen i baggrunden"

#: data/moe.ekusu.sprogskole.gschema.xml:65
msgid "Used while a session is active and background sync is enabled."
msgstr ""
"Bruges, mens en session er aktiv, og baggrundssynkronisering er slået til."

#: data/moe.ekusu.sprogskole.gschema.xml:69
msgid "Notify when new grades appear"
msgstr "Giv besked om nye karakterer"

#: data/moe.ekusu.sprogskole.gschema.xml:70
msgid ""
"Detected by the background refresh against the grades already seen; off by "
"default."
msgstr "Registreres af baggrundsopdateringen ud fra de allerede sete karakterer; slået fra som standard."

#: data/moe.ekusu.sprogskole.gschema.xml:74
msgid "Notify when new exams are scheduled"
msgstr "Giv besked om nye eksamener"

#: data/moe.ekusu.sprogskole.gschema.xml:75
msgid ""
"An exam is an upcoming lesson the school marks as non-skippable; off by "
"default."
msgstr "En eksamen er en kommende lektion, som skolen markerer som ikke til at springe over; slået fra som standard."

#: data/moe.ekusu.sprogskole.gschema.xml:79
msgid "Unix time (seconds) the saved session token is valid until"
msgstr "Unix-tid (sekunder) som det gemte sessionstoken er gyldigt indtil"

#: data/moe.ekusu.sprogskole.gschema.xml:80
msgid ""
"From the JWT 'exp' claim. 0 means unknown (no expiry claim); the token is "
"still tried."
msgstr ""
"Fra JWT-'exp'-claimet. 0 betyder ukendt (intet udløbs-claim); tokenet prøves "
"alligevel."

