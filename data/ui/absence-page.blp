using Gtk 4.0;
using Adw 1;

template $OpensprogskoleAbsencePage: Adw.Bin {
  child: Adw.ToastOverlay toast_overlay {
    child: ScrolledWindow {
      hscrollbar-policy: never;

      Adw.Clamp {
        maximum-size: 680;
        margin-top: 18;
        margin-bottom: 24;
        margin-start: 12;
        margin-end: 12;
        tightening-threshold: 280;

        Box {
          orientation: vertical;
          spacing: 18;

          Box {
            orientation: horizontal;
            homogeneous: false;

            Label {
              label: _("Absence");
              halign: start;
              hexpand: true;

              styles [
                "title-2",
              ]
            }

            Button report_button {
              icon-name: "list-add-symbolic";
              valign: center;
              accessibility {
                description: _("Report absence");
              }
              accessible-role: button;

              styles [
                "pill",
                "warning",
              ]
            }
          }

          // Editable, student-reported absences (GetFutureStudentAbsence). The
          // first few show directly; any extras tuck behind a "Show more" row so
          // they don't crowd out the reported list. Hidden until there is at
          // least one; all rows are filled in code.
          Adw.PreferencesGroup planned_group {
            title: _("Planned");
            visible: false;
          }

          // The read-only registered absences, with their own load state.
          Box {
            orientation: vertical;
            spacing: 8;

            Label {
              label: _("Reported");
              halign: start;

              styles [
                "title-4",
              ]
            }

            Stack stack {
              StackPage {
                name: "loading";

                child: $OpensprogskoleLoadingState absence_loading {
                  label: _("Loading absences…");
                };
              }

              StackPage {
                name: "list";

                child: ListBox list {
                  selection-mode: none;
                  valign: start;

                  styles [
                    "boxed-list",
                  ]
                };
              }

              StackPage {
                name: "empty";

                child: Label {
                  label: _("No reported absences yet.");
                  halign: center;
                  margin-top: 24;
                  margin-bottom: 24;

                  styles [
                    "dim-label",
                  ]
                };
              }
            }
          }
        }
      }
    };
  };
}
