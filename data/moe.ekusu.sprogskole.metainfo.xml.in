<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
  <id>moe.ekusu.sprogskole</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>OpenSprogskole</name>
  <summary>Your language school life</summary>
  <description>
    <p>View your schedule, grades, homework and report when you are sick or unavailable.</p>
  </description>

  <developer id="moe.ekusu.sprogskole">
    <name translatable="no">000exploit</name>
  </developer>

  <provides>
    <binary>moe.ekusu.sprogskole</binary>
  </provides>

  <url type="homepage">https://github.com/000exploit/opensprogskole-assisted</url>
  <url type="vcs-browser">https://github.com/000exploit/opensprogskole-assisted</url>
  <url type="bugtracker">https://github.com/000exploit/opensprogskole-assisted/issues</url>
  <url type="help">https://github.com/000exploit/opensprogskole-assisted/blob/main/README.md</url>
  <url type="contribute">https://github.com/000exploit/opensprogskole-assisted</url>

  <translation type="gettext">opensprogskole</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">moe.ekusu.sprogskole.desktop</launchable>
  <content_rating type="oars-1.1">
    <content_attribute id="social-info">mild</content_attribute>
  </content_rating>


  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/000exploit/opensprogskole-assisted/refs/heads/main/data/screenshots/greetings.png</image>
      <caption>Greetings</caption>
    </screenshot>
  </screenshots>

  <requires>
    <internet>always</internet>
  </requires>

  <releases>
    <release type="development" version="0.9.10" date="2026-07-12T11:23:43Z">
      <description>
        <p>This release features a lot of new stuff, the most noticeable are the modular overview page, shareable school configs, the new mobile view and just polishing.</p>
        <p>This release adds the following features:</p>
        <ul>
          <li>Background sync</li>
          <li>Added notifications for scheduled exams and new grades</li>
          <li>Error dialog, just in case</li>
          <li>Scrollable calendar on the schedule page</li>
          <li>Navigation overhaul with handy mobile view</li>
          <li>Preferences: now it's possible to change app settings</li>
          <li>School config: share non-standard configurations with your friends</li>
          <li>Overview: new, completely modular and adaptive for different schools</li>
        </ul>
        <p>This release includes the following changes:</p>
        <ul>
          <li>More reliable caching, its loading and cleaning on logout</li>
          <li>Initial LUDUS API implementation</li>
          <li>Enforced HTTPS</li>
          <li>Bearer token leaking prevention</li>
          <li>Added Danish, Russian and Ukrainian translations</li>
        </ul>
      </description>
    </release>
    <release type="stable" version="0.9.9" date="2026-06-28T00:00:00Z">
      <description>
        <p>This release adds the following features:</p>
        <ul>
          <li>Initial android port</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
